# Server (Vercel) — set in project Environment Variables, then redeploy so /api/boarding and /api/export see them.
PASS_TOKEN_SECRET=change-me-to-a-long-random-string-at-least-32-chars
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Client (Vite) — optional overrides for payment handles shown in boarding UI
VITE_VENMO_HANDLE=@GoldenBachdoor
VITE_PAYPAL_HANDLE=goldenbackdoorhitfactory@gmail.com
VITE_CASHAPP_HANDLE=$GoldenBachdoor
VITE_BOOKING_EMAIL=valetpru@gmail.com
VITE_CATALOG_EMAIL=goldenbackdoorhitfactory@gmail.com

