# Server — optional for legacy /api/export JWT audit only.
# Boarding is CLIENT-ONLY honor (localStorage on device) — POST /api/boarding returns 410.
#
# Optional — legacy /api/export JWT audit only (honor boarding does not use this):
# PASS_TOKEN_SECRET=change-me-to-a-long-random-string-at-least-32-chars
# Alternates: JWT_SECRET, AUTH_SECRET, QUESTFEST_PASS_TOKEN_SECRET (see lib/pass-env.mjs)
#
# Preview/local ONLY — never enable on Production (anyone can forge passes with the known dev key):
# QUESTFEST_ALLOW_INSECURE_PASS_SIGNING=1
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Server catalog uploads (Vercel Blob + manifest) — required for Bridge Upload tab
# Create a Blob store in Vercel → copies BLOB_READ_WRITE_TOKEN automatically.
# Use the same secret string on server and client (≥8 chars):
CATALOG_UPLOAD_SECRET=change-me-catalog-upload-secret-min-8-chars
# Client build (Vite) — must match CATALOG_UPLOAD_SECRET above:
VITE_CATALOG_UPLOAD_SECRET=change-me-catalog-upload-secret-min-8-chars
# Or omit VITE_CATALOG_UPLOAD_SECRET and set VITE_CAPTAIN_BYPASS_PASSWORD to the same value as CATALOG_UPLOAD_SECRET.

# Client (Vite) — optional overrides for payment handles shown in boarding UI
VITE_VENMO_HANDLE=@Pru-Mendez
VITE_PAYPAL_HANDLE=valetpru@gmail.com
VITE_CASHAPP_HANDLE=$GoldenBachdoor
# Optional — paypal.me/<slug>/<amount> for “Open PayPal” boarding/export links (defaults to email local-part before @)
# VITE_PAYPAL_PAYPALME=YourPayPalMeSlug
VITE_BOOKING_EMAIL=valetpru@gmail.com
VITE_CATALOG_EMAIL=valetpru@gmail.com
# Optional — Machote Moderno Magazine follow URL (qualifier for $16.18/mo members pass)
# VITE_MACHOTE_MAGAZINE_URL=https://www.facebook.com/share/1BcDYXVuQK/?mibextid=wwXIfr

# Optional — captain / operator unlock password (client-visible). If unset, the app uses the edge default.
# VITE_CAPTAIN_BYPASS_PASSWORD=

# Optional — neural male anchor voice for executive onboarding newscast (POST /api/executive-onboard-tts)
# OPENAI_API_KEY=sk-...

# Lattice V1.618 chat (POST /api/lattice-chat) — SERVER ONLY. Never commit real values.
# Do NOT put CURSOR_API_KEY in Vite / client code.
# Create Cursor key at https://cursor.com/dashboard/integrations (Pro usage pool).
# CURSOR_API_KEY=
# Old-school access: email allowlist in data/lattice-access.json (no passwords).
# Creator valetpru@gmail.com is permanent. Guests (1 month):
#   node scripts/lattice-grant-access.mjs someone@example.com
# Public contact shown in UI:
# LATTICE_ACCESS_EMAIL=valetpru@gmail.com
# VITE_LATTICE_ACCESS_EMAIL=valetpru@gmail.com
# Optional overrides:
# LATTICE_REPO_URL=https://github.com/FractiAI/psw.vibelandia.sing13
# LATTICE_MODEL_ID=composer-2.5

# Coherence / Goldilocks rail (server only — not exposed on public web)
# Fixed payout on every pulse. Change only in Vercel env + redeploy (no public POST).
# COHERENCE_OPERATIONAL_ANCHOR=0x3563388d0e1c2d66a004e5e57717dc6d7e568be3
# COHERENCE_AUTOPILOT=1
# GOLDILOCKS_PULSE_SECRET=
# CRON_SECRET=
# Simulated mining fleet hashrate (H/s) — default 1.618 PH/s if unset
# COHERENCE_SIM_HASHRATE_H=1618000000000000
# Or fraction of live network hashrate (overrides fixed H/s when set)
# COHERENCE_SIM_HASHRATE_FRACTION=0.000001618

# Turner bison / radar — set to 1 only for legacy mode (synthetic soil fallback, φ-squashed Kp floor, spatial fence phase, RNG weight spread). Default is real-remote feeds only.
# TURNER_ALLOW_SYNTHETIC=1

# Turner — passive fence read from real OpenWebRX downstream (server pulls `wss://`, no browser CORS).
# Default: public internet receive-only OpenWebRX + live fence coordinates (OSM / turner-perimeter-steel.geojson).
# No on-premise SDR at Turner is required. Optional upgrade: point URL at receive-only OpenWebRX on/near the ranch
# to improve ability and operational fidelity (ranch-local passband; still mapped to fence GIS in the model).
# TURNER_SDR_WSS_URL=wss://your-openwebrx-host.example.com/ws/
# TURNER_SDR_LABEL=operator-rx
# TURNER_SDR_TUNE_HZ=1420400000
# TURNER_SDR_LIVE=1
# TURNER_OPENWEBRX_LIVE=1
# Prefer FFT spectrum frames over first audio (helps per-gate coupling from spectral bins). Auto-on when TURNER_SDR_WSS_URL is set unless TURNER_SDR_FFT=0.
# TURNER_SDR_FFT=1

# Turner — optional fusion calibration (bounded pseudo-correlation nudge only; not NDVI, not collar truth).
# Uses Open-Meteo FAO-56 ET₀ (mm/day) time-aligned with the fuse + a small bump when real OpenWebRX per-gate spectrum mapping is active.
# TURNER_FUSION_SURFACE_CALIB=1
# TURNER_FUSION_CAL_ET0_WEIGHT=0.018
# TURNER_FUSION_CAL_SDR_MAP_WEIGHT=0.014

# Turner — triangulated lock-in (default on): NASA POWER skin temp (IR proxy) + GPS steel fence GeoJSON + Digital Pru φ-gate
# TURNER_SATELLITE_LST=0
# TURNER_PERIMETER_STEEL=0
# TURNER_DIGITAL_PRU_LOCK=0
# TURNER_FUSION_LOCK_LST_WEIGHT=0.022
# TURNER_FUSION_LOCK_STEEL_WEIGHT=0.035
# TURNER_GRID_STEEL_COUPLING_BOOST=0.18
# Fence lines: OpenStreetMap Overpass (default) · optional override data/turner-perimeter-steel.geojson
# TURNER_FENCE_OSM=0
# TURNER_OVERPASS_URL=https://overpass-api.de/api/interpreter

# Turner — space-bio ranch log (Open-Meteo column + S2 STAC + RF readouts) is always on in live pipeline; no env toggle.
