# Server — optional for legacy /api/export JWT audit only.
# Boarding is CLIENT-ONLY honor (localStorage on device) — POST /api/boarding returns 410.
#
# Optional — legacy /api/export JWT audit only (honor boarding does not use this):
# PASS_TOKEN_SECRET=change-me-to-a-long-random-string-at-least-32-chars
# Alternates: JWT_SECRET, AUTH_SECRET, QUESTFEST_PASS_TOKEN_SECRET (see lib/pass-env.mjs)
#
# Preview/local ONLY — never enable on Production (anyone can forge passes with the known dev key):
# QUESTFEST_ALLOW_INSECURE_PASS_SIGNING=1
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Server catalog uploads (Vercel Blob + manifest) — required for Bridge Upload tab
# Create a Blob store in Vercel → copies BLOB_READ_WRITE_TOKEN automatically.
# Use the same secret string on server and client (≥8 chars):
CATALOG_UPLOAD_SECRET=change-me-catalog-upload-secret-min-8-chars
# Client build (Vite) — must match CATALOG_UPLOAD_SECRET above:
VITE_CATALOG_UPLOAD_SECRET=change-me-catalog-upload-secret-min-8-chars
# Or omit VITE_CATALOG_UPLOAD_SECRET and set VITE_CAPTAIN_BYPASS_PASSWORD to the same value as CATALOG_UPLOAD_SECRET.

# Client (Vite) — optional overrides for payment handles shown in boarding UI
VITE_VENMO_HANDLE=@Pru-Mendez
VITE_PAYPAL_HANDLE=valetpru@gmail.com
VITE_CASHAPP_HANDLE=$GoldenBachdoor
# Optional — paypal.me/<slug>/<amount> for “Open PayPal” boarding/export links (defaults to email local-part before @)
# VITE_PAYPAL_PAYPALME=YourPayPalMeSlug
VITE_BOOKING_EMAIL=valetpru@gmail.com
VITE_CATALOG_EMAIL=valetpru@gmail.com
# Optional — Machote Moderno Magazine follow URL (qualifier for $16.18/mo members pass)
# VITE_MACHOTE_MAGAZINE_URL=https://www.facebook.com/share/1BcDYXVuQK/?mibextid=wwXIfr

# Optional — captain / operator unlock password (client-visible). If unset, the app uses the edge default.
# VITE_CAPTAIN_BYPASS_PASSWORD=

# Coherence / Goldilocks rail (server only — not exposed on public web)
# Fixed payout on every pulse. Change only in Vercel env + redeploy (no public POST).
# COHERENCE_OPERATIONAL_ANCHOR=0x3563388d0e1c2d66a004e5e57717dc6d7e568be3
# COHERENCE_AUTOPILOT=1
# GOLDILOCKS_PULSE_SECRET=
# CRON_SECRET=
