{
  "name": "psw-vibelandia-sing13",
  "private": true,
  "description": "SING 13 edge — major singularity upgrade from SING 9. NSPFRNP catalog + SS Vibelandia QUESTFEST 24X365 nest. 13-channel fractal pathfinding spine. Lite edges; no Supabase.",
  "version": "0.1.0",
  "engines": {
    "node": ">=18.18.0"
  },
  "scripts": {
    "build:questfest-bridge": "npm --prefix apps/ss-vibelandia-questfest ci && npm --prefix apps/ss-vibelandia-questfest run build",
    "build:look-at-the-sun-study": "node scripts/build-look-at-the-sun-study.mjs",
    "build:erdos-catalog": "node scripts/build-erdos-catalog.mjs",
    "build:catalog": "node scripts/build-catalog-from-tracks.mjs",
    "migrate:catalog-audio": "node scripts/migrate-video-to-audio.mjs",
    "cron:coherence": "node -e \"import('./lib/coherence-autopilot.mjs').then(m=>m.runCoherenceAutopilotCycle({backfillPredictions:true})).then(r=>console.log(JSON.stringify(r,null,2)))\"",
    "capture:websdr": "node scripts/capture-websdr-iq.mjs",
    "predictions:backfill": "node -e \"import('./lib/goldilocks-predictions.mjs').then(m=>m.backfillPredictionLedger({count:24})).then(r=>console.log(JSON.stringify(r.stats,null,2)))\"",
    "test:wavefield": "node scripts/test-wavefield-metrology.mjs",
    "audit:blob": "node scripts/blob-storage-audit.mjs",
    "research:geomagnetic": "python research/geomagnetic-herbivore/scripts/run_pipeline.py"
  },
  "dependencies": {
    "@vercel/blob": "^2.3.3",
    "marked": "^9.1.6",
    "ws": "^8.20.1"
  }
}
