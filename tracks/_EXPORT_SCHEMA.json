{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Juicy Juicy - Snap OFC MusicalMetadataScore",
  "type": "object",
  "required": ["compiler", "verses"],
  "properties": {
    "compiler": { "const": "Juicy Juicy - Snap Omniversal Fractal Compiler (OFC)" },
    "hero_jo_hit_factory": { "type": "boolean" },
    "bpm_suggestion": { "type": "integer" },
    "verses": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["bar", "jj_holographic"],
        "properties": {
          "bar": { "type": "integer" },
          "jj_holographic": { "type": "string" },
          "qihoh_lane": { "type": "string" },
          "phi_weight": { "type": "number" }
        }
      }
    }
  }
}
