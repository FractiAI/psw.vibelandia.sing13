  "crons": [
    {
      "path": "/api/cron-coherence-rail",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron-websdr-capture",
      "schedule": "*/10 * * * *"
    },
    {
      "path": "/api/cron-turner-bison-ingest",
      "schedule": "*/5 * * * *"
    }
  ],
  "functions": {
    "api/catalog.js": {
      "memory": 512,
      "maxDuration": 30
    },
    "api/catalog-upload.js": {
      "memory": 1024,
      "maxDuration": 300
    },
    "api/catalog-track.js": {
      "memory": 1024,
      "maxDuration": 60
    },
    "api/cron-coherence-rail.js": {
      "memory": 512,
      "maxDuration": 60
    },
    "api/cron-websdr-capture.js": {
      "memory": 512,
      "maxDuration": 60
    },
    "api/websdr-iq.js": {
      "memory": 512,
      "maxDuration": 60
    },
    "api/goldilocks-pulse.js": {
      "memory": 512,
      "maxDuration": 60
    },
    "api/goldilocks-predictions.js": {
      "memory": 512,
      "maxDuration": 60
    },
    "api/whitepaper.js": {
      "memory": 512,
      "maxDuration": 30,
      "includeFiles": "{docs/**,protocols/**,data/synthobs-paper-audits/**,data/synthobs-agent-manifest.json,BBHE_REPOSITORY_STANDARD.md,lib/**}"
    },
    "api/synthobs-paper-audit.js": {
      "memory": 512,
      "maxDuration": 120,
      "includeFiles": "{docs/**,data/**,lib/**}"
    },
    "api/whitepaper-catalog.js": {
      "memory": 256,
      "maxDuration": 15,
      "includeFiles": "{lib/**,data/synthobs-paper-audit-index.json}"
    },
    "api/dph-wavefield-solar.js": {
      "memory": 512,
      "maxDuration": 60,
      "includeFiles": "lib/**"
    },
    "api/turner-bison-telemetry.js": {
      "memory": 512,
      "maxDuration": 300,
      "includeFiles": "{data/**,lib/**}"
    },
    "api/turner-recent-anomaly-report.js": {
      "memory": 512,
      "maxDuration": 300,
      "includeFiles": "{data/**,lib/**}"
    },
    "api/cron-turner-bison-ingest.js": {
      "memory": 512,
      "maxDuration": 60,
      "includeFiles": "{data/**,lib/**}"
    },
    "api/bulletin-board.js": {
      "memory": 256,
      "maxDuration": 15,
      "includeFiles": "data/bulletin-board-posts.json"
    }
  },
  "headers": [
    {
      "source": "/interfaces/questfest-bridge/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/interfaces/questfest-bridge/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/media/catalog/catalog.json",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=60, stale-while-revalidate=300" }
      ]
    },
    {
      "source": "/media/catalog/tracks/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Protocol", "value": "NSPFRNP" },
        { "key": "X-Octave-0", "value": "Seed" },
        { "key": "X-Octave-1", "value": "Edge" },
        { "key": "X-Singularity", "value": "Sonic Singularity Sing! 13" },
        { "key": "X-Parent-Edge", "value": "https://psw-vibelandia-sing9.vercel.app" }
      ]
    }
  ]
}
